---
interface Props {
  num: string;
  title: string;
  subtitle: string;
  body: string;
  image: string;
  reverse?: boolean;
  href?: string;
}

const { num, title, subtitle, body, image, reverse = false, href } = Astro.props;
---

<section class="servicio-detalle relative min-h-[100svh] flex items-center overflow-hidden">

  <!-- Imagen de fondo a media pantalla -->
  <div class={`absolute inset-y-0 ${reverse ? 'left-0' : 'right-0'} w-full md:w-1/2 z-0`}>
    <div class="absolute inset-0 bg-noche/65 z-10"></div>
    <img
      src={image}
      alt={title}
      loading="lazy"
      decoding="async"
      class="servicio-img w-full h-full object-cover"
    />
  </div>

  <!-- Texto sobre fondo oscuro -->
  <div class={`relative z-20 w-full md:w-1/2 px-6 md:px-16 py-24 ${reverse ? 'md:ml-auto' : ''}`}>
    <div class="servicio-content flex flex-col gap-6 max-w-lg opacity-0">

      <span class="font-serif text-7xl text-oro/30 leading-none">{num}</span>

      <div class="w-12 h-px bg-oro"></div>

      <h2 class="font-serif text-[clamp(2rem,5vw,4rem)] leading-tight text-pergamino uppercase tracking-wide">
        {title}
      </h2>

      <p class="font-serif italic text-oro text-xl md:text-2xl leading-relaxed">
        {subtitle}
      </p>

      <p class="font-sans text-base md:text-lg text-pergamino/95 leading-relaxed">
        {body}
      </p>

      {href && (
        <a
          href={href}
          class="mt-4 inline-flex items-center gap-4 font-sans text-sm tracking-[0.3em] uppercase text-pergamino hover:text-oro transition-colors duration-300 group font-medium"
        >
          <span>Ver servicio</span>
          <span class="block w-10 h-px bg-pergamino group-hover:bg-oro group-hover:w-16 transition-all duration-300"></span>
        </a>
      )}

    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.servicio-detalle').forEach((el) => {
    const content = el.querySelector('.servicio-content');
    if (content) {
      gsap.to(content, {
        scrollTrigger: { trigger: el, start: 'top 70%' },
        opacity: 1, y: 0, duration: 1, ease: 'power3.out',
      });
      gsap.from(content, { y: 40 });
    }

    const img = el.querySelector('.servicio-img');
    if (img) {
      gsap.to(img, {
        scrollTrigger: {
          trigger: el,
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
        yPercent: -15,
        ease: 'none',
      });
    }
  });
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .bg-oro         { background-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
</style>
