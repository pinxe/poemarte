---
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative min-h-[60vh] flex flex-col items-center justify-end pb-24 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-noche/70 z-10"></div>
    <img src="/images/servicios-hero.jpg" alt="" aria-hidden="true" class="w-full h-full object-cover" />
  </div>

  <div class="relative z-20 text-center px-8">
    <p class="serv-eyebrow font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-6 opacity-0">
      {t('services.title')}
    </p>
    <h1 class="serv-title font-serif text-[clamp(3rem,10vw,8rem)] leading-none text-pergamino tracking-[0.1em] uppercase opacity-0">
      {t('services.title')}
    </h1>
    <p class="serv-tag font-serif italic text-ceniza text-lg mt-6 max-w-xl mx-auto opacity-0">
      Cada servicio es una manera de tejer arte y palabra.
    </p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  const tl = gsap.timeline({ delay: 0.3 });
  tl.to('.serv-eyebrow', { opacity: 1, duration: 0.8, ease: 'power2.out' })
    .to('.serv-title',   { opacity: 1, duration: 1.2, ease: 'power2.out' }, '-=0.4')
    .to('.serv-tag',     { opacity: 1, duration: 0.8, ease: 'power2.out' }, '-=0.5');
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
</style>
