---
interface Props {
  eyebrow: string;
  title: string;
  tagline: string;
  image: string;
}

const { eyebrow, title, tagline, image } = Astro.props;
---

<section class="relative min-h-[60vh] flex flex-col items-center justify-end pb-24 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-noche/70 z-10"></div>
    <img src={image} alt="" aria-hidden="true" class="w-full h-full object-cover" />
  </div>

  <div class="relative z-20 text-center px-8">
    <p class="serv-eyebrow font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-6 opacity-0">{eyebrow}</p>
    <h1 class="serv-title font-serif text-[clamp(2.5rem,8vw,8rem)] leading-tight md:leading-none text-pergamino tracking-[0.1em] uppercase opacity-0">{title}</h1>
    <p class="serv-tag font-serif italic text-ceniza text-base md:text-lg mt-6 max-w-xl mx-auto opacity-0">{tagline}</p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  const tl = gsap.timeline({ delay: 0.3 });
  tl.to('.serv-eyebrow', { opacity: 1, duration: 0.8, ease: 'power2.out' })
    .to('.serv-title',   { opacity: 1, duration: 1.2, ease: 'power2.out' }, '-=0.4')
    .to('.serv-tag',     { opacity: 1, duration: 0.8, ease: 'power2.out' }, '-=0.5');
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
</style>
