---
import { getCookies } from '../lib/content';

const cookies = await getCookies();
---

{cookies && cookies.enabled && (
  <div
    id="cookie-banner"
    class="fixed bottom-0 left-0 right-0 z-[9990] hidden"
    role="dialog"
    aria-live="polite"
    aria-label={cookies.title}
  >
    <div class="bg-noche/95 backdrop-blur-md border-t border-pergamino/15 px-6 py-6 md:px-12 md:py-7">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center gap-5 md:gap-8">
        <div class="flex-1">
          <p class="font-serif text-pergamino text-lg md:text-xl mb-2">{cookies.title}</p>
          <p class="font-sans text-sm md:text-base text-pergamino/85 leading-relaxed">
            {cookies.message}
            {cookies.policyHref && (
              <>
                {' '}
                <a href={cookies.policyHref} class="text-oro underline underline-offset-2 hover:text-pergamino transition-colors">{cookies.policyLabel}</a>.
              </>
            )}
          </p>
        </div>
        <div class="flex gap-3 md:gap-4 shrink-0">
          <button
            type="button"
            data-cookie-action="reject"
            class="font-sans text-xs tracking-[0.25em] uppercase font-medium px-5 py-3 border border-pergamino/30 text-pergamino hover:border-pergamino hover:bg-pergamino/5 transition-colors duration-300"
          >
            {cookies.rejectLabel}
          </button>
          <button
            type="button"
            data-cookie-action="accept"
            class="font-sans text-xs tracking-[0.25em] uppercase font-medium px-5 py-3 bg-oro text-noche hover:bg-pergamino transition-colors duration-300"
          >
            {cookies.acceptLabel}
          </button>
        </div>
      </div>
    </div>
  </div>
)}

<script>
  const STORAGE_KEY = 'poemarte_cookies_consent';
  const banner = document.getElementById('cookie-banner');
  if (banner) {
    const existing = (() => {
      try { return localStorage.getItem(STORAGE_KEY); } catch { return null; }
    })();

    if (!existing) {
      banner.classList.remove('hidden');
    }

    const setConsent = (value: 'accepted' | 'rejected') => {
      try { localStorage.setItem(STORAGE_KEY, value); } catch {}
      banner.classList.add('hidden');
      document.dispatchEvent(new CustomEvent('poemarte:cookie-consent', { detail: value }));
    };

    banner.querySelectorAll<HTMLButtonElement>('[data-cookie-action]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.cookieAction;
        setConsent(action === 'accept' ? 'accepted' : 'rejected');
      });
    });
  }
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .bg-oro         { background-color: var(--color-oro); }
  .text-noche     { color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-oro       { color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
</style>
