---
import { useTranslations, getLocalePath, locales } from '../i18n';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath = '' } = Astro.props;
const t = useTranslations(locale);

const navLinks = [
  { key: 'nav.home',     href: getLocalePath(locale) },
  { key: 'nav.about',    href: getLocalePath(locale, 'sobre') },
  { key: 'nav.services', href: getLocalePath(locale, 'servicios') },
  { key: 'nav.contact',  href: getLocalePath(locale, 'contacto') },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-out"
>
  <nav class="flex items-center justify-between px-8 py-6 md:px-16 transition-all duration-500">

    <!-- Logo -->
    <a href={getLocalePath(locale)} class="font-serif text-xl tracking-widest text-pergamino uppercase">
      Poemarte
    </a>

    <!-- Links -->
    <ul class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="font-sans text-xs tracking-[0.2em] uppercase text-pergamino/90 hover:text-oro transition-colors duration-300 font-medium"
          >
            {t(link.key)}
          </a>
        </li>
      ))}
    </ul>

    <!-- Selector de idioma -->
    <div class="flex items-center gap-3">
      {locales.map(loc => (
        <a
          href={getLocalePath(loc, currentPath)}
          class={`text-xs tracking-widest uppercase transition-colors duration-300 ${
            loc === locale
              ? 'text-oro'
              : 'text-pergamino/40 hover:text-pergamino/70'
          }`}
        >
          {loc}
        </a>
      ))}
    </div>

    <!-- Hamburger (mobile) -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Menú"
    >
      <span class="block w-6 h-px bg-pergamino transition-all duration-300"></span>
      <span class="block w-4 h-px bg-pergamino transition-all duration-300"></span>
    </button>

  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-noche flex flex-col items-center justify-center gap-10 z-40">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="font-serif text-3xl italic text-pergamino hover:text-oro transition-colors duration-300"
      >
        {t(link.key)}
      </a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  // Header con fondo al hacer scroll
  const header = document.getElementById('site-header');
  const nav = header?.querySelector('nav');

  const handleScroll = () => {
    if (!header || !nav) return;
    if (window.scrollY > 40) {
      header.classList.add('is-scrolled');
      nav.classList.add('is-scrolled-nav');
    } else {
      header.classList.remove('is-scrolled');
      nav.classList.remove('is-scrolled-nav');
    }
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<style>
  .text-pergamino { color: var(--color-pergamino); }
  .text-oro       { color: var(--color-oro); }
  .bg-noche       { background-color: var(--color-noche); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }

  /* Estado por defecto: transparente */
  #site-header {
    background-color: transparent;
    backdrop-filter: none;
    border-bottom: 1px solid transparent;
  }

  /* Estado scrolled: fondo oscuro con blur */
  #site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--color-noche) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-pergamino) 8%, transparent);
  }

  /* Cuando scrolled, padding más compacto */
  nav.is-scrolled-nav {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
</style>
