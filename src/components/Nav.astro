---
import { useTranslations, getLocalePath } from '../i18n';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const navLinks = [
  { key: 'nav.home',     href: getLocalePath(locale) },
  { key: 'nav.about',    href: getLocalePath(locale, 'sobre') },
  { key: 'nav.services', href: getLocalePath(locale, 'servicios') },
  { key: 'nav.contact',  href: getLocalePath(locale, 'contacto') },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-out">
  <nav class="flex items-center justify-between px-6 py-5 md:px-16 md:py-6 transition-all duration-500">

    <a href={getLocalePath(locale)} class="font-serif text-lg md:text-xl tracking-widest text-pergamino uppercase">
      Poemarte
    </a>

    <ul class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="font-sans text-xs tracking-[0.2em] uppercase text-pergamino/90 hover:text-oro transition-colors duration-300 font-medium">
            {t(link.key)}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-3 -mr-3"
      aria-label={t('ui.menu')}
      aria-expanded="false"
    >
      <span class="bar block w-6 h-px bg-pergamino transition-all duration-300"></span>
      <span class="bar block w-4 h-px bg-pergamino transition-all duration-300"></span>
    </button>

  </nav>

  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-noche flex-col items-center justify-center gap-10 z-40">
    {navLinks.map(link => (
      <a href={link.href} class="font-serif text-3xl italic text-pergamino hover:text-oro transition-colors duration-300">
        {t(link.key)}
      </a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bars = toggle?.querySelectorAll('.bar');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex', !open);
    toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
    document.body.style.overflow = open ? '' : 'hidden';
    if (bars && bars.length >= 2) {
      (bars[0] as HTMLElement).style.width = open ? '1.5rem' : '1.5rem';
      (bars[1] as HTMLElement).style.width = open ? '1rem' : '1.5rem';
    }
  });

  // Cerrar al pulsar un link
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });

  const header = document.getElementById('site-header');
  const nav = header?.querySelector('nav');

  const handleScroll = () => {
    if (!header || !nav) return;
    if (window.scrollY > 40) {
      header.classList.add('is-scrolled');
      nav.classList.add('is-scrolled-nav');
    } else {
      header.classList.remove('is-scrolled');
      nav.classList.remove('is-scrolled-nav');
    }
  };

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<style>
  .text-pergamino { color: var(--color-pergamino); }
  .text-oro       { color: var(--color-oro); }
  .bg-noche       { background-color: var(--color-noche); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }

  #site-header {
    background-color: transparent;
    backdrop-filter: none;
    border-bottom: 1px solid transparent;
  }

  #site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--color-noche) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-pergamino) 8%, transparent);
  }

  nav.is-scrolled-nav {
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }
</style>
