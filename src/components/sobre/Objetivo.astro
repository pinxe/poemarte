---
interface Props {
  title: string;
  quote: string;
  body: string;
  image: string;
}

const { title, quote, body, image } = Astro.props;
const paragraphs = body.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---

<section class="py-section px-8 md:px-16 bg-noche">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 md:gap-32 items-center">

    <div class="obj-img relative order-2 md:order-1">
      <div class="aspect-[4/5] overflow-hidden">
        <img src={image} alt={title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
      </div>
      <div class="absolute -bottom-6 -right-6 w-full h-full border border-oro/20 z-[-1]"></div>
    </div>

    <div class="obj-text flex flex-col gap-8 order-1 md:order-2">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro">{title}</p>
      <h2 class="font-serif text-[clamp(2rem,4vw,3.5rem)] leading-tight text-pergamino">{title}</h2>
      <p class="font-serif italic text-ceniza text-lg border-l-2 border-oro pl-6 leading-relaxed">{quote}</p>
      <div class="flex flex-col gap-4">
        {paragraphs.map(p => (
          <p class="font-sans text-base text-pergamino/80 leading-relaxed">{p}</p>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.obj-img',
    { x: -50, opacity: 0 },
    { scrollTrigger: { trigger: '.obj-img', start: 'top 90%' }, x: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
  gsap.fromTo('.obj-text',
    { x: 50, opacity: 0 },
    { scrollTrigger: { trigger: '.obj-text', start: 'top 90%' }, x: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .border-oro     { border-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
