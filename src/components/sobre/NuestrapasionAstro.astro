---
interface Tip { title: string; body: string; }

interface Props {
  title: string;
  introQuote: string;
  introBody: string;
  banner: string;
  bannerQuote: string;
  tips: Tip[];
}

const { title, introQuote, introBody, banner, bannerQuote, tips } = Astro.props;
---

<section class="py-section px-8 md:px-16 bg-noche overflow-hidden">
  <div class="max-w-7xl mx-auto">

    <div class="passion-header grid md:grid-cols-2 gap-10 md:gap-16 items-end mb-16 md:mb-20">
      <div>
        <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-6">{title}</p>
        <h2 class="font-serif text-[clamp(2rem,6vw,5rem)] leading-tight text-pergamino">{title}</h2>
      </div>
      <div class="flex flex-col gap-5">
        <p class="font-serif italic text-ceniza text-lg leading-relaxed">{introQuote}</p>
        <p class="font-sans text-base text-pergamino/80 leading-relaxed">{introBody}</p>
      </div>
    </div>

    <div class="passion-img relative mb-16 md:mb-20">
      <div class="aspect-[16/9] md:aspect-[16/6] overflow-hidden">
        <img src={banner} alt={title} class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-noche/85 via-noche/50 to-transparent"></div>
      </div>
      <div class="absolute inset-0 flex items-center px-6 md:px-20">
        <blockquote class="max-w-lg">
          <p class="font-serif italic text-pergamino text-xl md:text-3xl leading-relaxed">"{bannerQuote}"</p>
        </blockquote>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-pergamino/10">
      {tips.map((tip, i) => (
        <div class="tip-card bg-noche p-8 md:p-10 flex flex-col gap-4">
          <span class="font-serif text-5xl text-oro/20 leading-none">0{i + 1}</span>
          <h3 class="font-serif text-pergamino text-xl leading-tight">{tip.title}</h3>
          <p class="font-sans text-pergamino/85 text-base leading-relaxed">{tip.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.passion-header',
    { y: 40, opacity: 0 },
    { scrollTrigger: { trigger: '.passion-header', start: 'top 90%' }, y: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
  gsap.fromTo('.passion-img',
    { opacity: 0 },
    { scrollTrigger: { trigger: '.passion-img', start: 'top 90%' }, opacity: 1, duration: 1.2, ease: 'power2.out' }
  );
  gsap.fromTo('.tip-card',
    { y: 30, opacity: 0 },
    { scrollTrigger: { trigger: '.tip-card', start: 'top 90%' }, y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: 'power3.out' }
  );
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
