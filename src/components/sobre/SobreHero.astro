---
interface Props {
  eyebrow: string;
  title: string;
  image: string;
}

const { eyebrow, title, image } = Astro.props;
---

<section class="relative min-h-[55svh] md:min-h-[60vh] flex flex-col items-center justify-end pb-24 overflow-hidden">

  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-noche/80 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-noche/40 via-transparent to-noche/70 z-10"></div>
    <img src={image} alt="" aria-hidden="true" loading="eager" fetchpriority="high" decoding="async" class="w-full h-full object-cover" />
  </div>

  <div class="relative z-20 text-center px-6 md:px-8">
    <p class="sobre-eyebrow font-sans text-sm tracking-[0.5em] uppercase text-oro mb-6 opacity-0 font-medium hero-shadow">{eyebrow}</p>
    <h1 class="sobre-title font-serif text-[clamp(2.5rem,8vw,8rem)] leading-tight md:leading-none text-pergamino tracking-[0.1em] uppercase opacity-0 hero-shadow">{title}</h1>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  const tl = gsap.timeline({ delay: 0.3 });
  tl.to('.sobre-eyebrow', { opacity: 1, duration: 0.8, ease: 'power2.out' })
    .to('.sobre-title',   { opacity: 1, duration: 1.2, ease: 'power2.out' }, '-=0.4');
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-oro       { color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .hero-shadow    { text-shadow: 0 2px 18px rgba(0,0,0,0.65), 0 1px 3px rgba(0,0,0,0.5); }
</style>
