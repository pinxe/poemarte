---
interface Props {
  title: string;
  quote: string;
  body: string;
  image: string;
}

const { title, quote, body, image } = Astro.props;
const paragraphs = body.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---

<section class="py-section px-8 md:px-16 bg-hueso">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 md:gap-32 items-center">

    <div class="qh-text flex flex-col gap-8">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro">{title}</p>
      <h2 class="font-serif text-[clamp(2rem,4vw,3rem)] leading-tight text-noche">{title}</h2>
      <p class="font-serif italic text-noche/75 text-lg border-l-2 border-oro pl-6 leading-relaxed">{quote}</p>
      <div class="flex flex-col gap-4 mt-4">
        {paragraphs.map(p => (
          <p class="font-sans text-base text-noche/85 leading-relaxed">{p}</p>
        ))}
      </div>
    </div>

    <div class="qh-img relative">
      <div class="aspect-[4/5] overflow-hidden">
        <img src={image} alt={title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
      </div>
      <div class="absolute -top-6 -left-6 w-full h-full border border-oro/20 z-[-1]"></div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.qh-text',
    { x: -50, opacity: 0 },
    { scrollTrigger: { trigger: '.qh-text', start: 'top 90%' }, x: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
  gsap.fromTo('.qh-img',
    { x: 50, opacity: 0 },
    { scrollTrigger: { trigger: '.qh-img', start: 'top 90%' }, x: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
</script>

<style>
  .bg-hueso   { background-color: var(--color-hueso); }
  .text-noche { color: var(--color-noche); }
  .text-oro   { color: var(--color-oro); }
  .border-oro { border-color: var(--color-oro); }
  .font-serif { font-family: var(--font-serif); }
  .font-sans  { font-family: var(--font-sans); }
  .py-section { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
