---
import { getLocalePath } from '../../i18n';
import type { Locale } from '../../i18n';

interface Opt { title: string; desc: string; items: string[]; }

interface Props {
  locale: Locale;
  title: string;
  intro: string;
  opts: Opt[];
  ctaText: string;
  ctaLabel: string;
}

const { locale, title, intro, opts, ctaText, ctaLabel } = Astro.props;
---

<section class="py-section px-8 md:px-16 bg-hueso">
  <div class="max-w-7xl mx-auto">

    <div class="precios-header text-center mb-16 md:mb-20">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-6">{title}</p>
      <h2 class="font-serif text-[clamp(2rem,5vw,4rem)] leading-tight text-noche">{title}</h2>
      <p class="font-sans text-base text-noche/75 mt-6 max-w-lg mx-auto leading-relaxed">{intro}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {opts.map((op, i) => (
        <div class="precio-card bg-noche flex flex-col gap-6 p-8 md:p-10 group hover:border-oro/30 border border-pergamino/5 transition-colors duration-300">
          <span class="font-serif text-5xl text-oro/20 leading-none">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="font-serif text-pergamino text-xl">{op.title}</h3>
          <p class="font-sans text-pergamino/85 text-base leading-relaxed flex-1">{op.desc}</p>
          <ul class="flex flex-col gap-2 border-t border-pergamino/10 pt-6">
            {op.items.map(item => (
              <li class="flex items-start gap-3 font-sans text-sm text-pergamino/75">
                <span class="text-oro mt-0.5 flex-shrink-0">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="text-center precios-cta">
      <p class="font-serif italic text-noche/75 mb-6 max-w-xl mx-auto">{ctaText}</p>
      <a
        href={getLocalePath(locale, 'contacto')}
        class="inline-flex items-center gap-4 font-sans text-xs tracking-[0.3em] uppercase text-noche hover:text-oro transition-colors duration-300 group"
      >
        <span>{ctaLabel}</span>
        <span class="block w-8 h-px bg-noche group-hover:bg-oro group-hover:w-12 transition-all duration-300"></span>
      </a>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.precios-header',
    { y: 40, opacity: 0 },
    { scrollTrigger: { trigger: '.precios-header', start: 'top 90%' }, y: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
  gsap.fromTo('.precio-card',
    { y: 40, opacity: 0 },
    { scrollTrigger: { trigger: '.precio-card', start: 'top 92%' }, y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: 'power3.out' }
  );
  gsap.fromTo('.precios-cta',
    { opacity: 0 },
    { scrollTrigger: { trigger: '.precios-cta', start: 'top 95%' }, opacity: 1, duration: 0.8, ease: 'power2.out' }
  );
</script>

<style>
  .bg-hueso       { background-color: var(--color-hueso); }
  .bg-noche       { background-color: var(--color-noche); }
  .text-noche     { color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
