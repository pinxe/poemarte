---
interface Fase {
  title: string;
  sub: string;
  body: string;
  image: string;
}

interface Props {
  title: string;
  intro: string;
  fases: Fase[];
}

const { title, intro, fases } = Astro.props;
---

<section class="py-section px-8 md:px-16 bg-hueso">
  <div class="max-w-7xl mx-auto">

    <div class="proceso-header text-center mb-16 md:mb-20">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-6">{title}</p>
      <h2 class="font-serif text-[clamp(2rem,5vw,4rem)] leading-tight text-noche max-w-2xl mx-auto">{title}</h2>
      <p class="font-serif italic text-noche/70 mt-6 max-w-xl mx-auto leading-relaxed">{intro}</p>
    </div>

    <div class="flex flex-col gap-0">
      {fases.map((fase, i) => (
        <div class="fase-row grid md:grid-cols-2 gap-0">

          <div class={`relative overflow-hidden aspect-[4/3] ${i % 2 === 1 ? 'md:order-2' : ''}`}>
            <img src={fase.image} alt={fase.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
            <span class="absolute top-6 left-6 font-serif text-7xl md:text-8xl text-hueso/20 leading-none pointer-events-none select-none">
              {String(i + 1).padStart(2, '0')}
            </span>
          </div>

          <div class={`bg-noche flex flex-col justify-center p-10 md:p-16 gap-6 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
            <div class="w-8 h-px bg-oro"></div>
            <h3 class="font-serif text-[clamp(1.5rem,3vw,2.5rem)] text-pergamino leading-tight">{fase.title}</h3>
            <p class="font-serif italic text-oro/80 text-base leading-relaxed">{fase.sub}</p>
            <p class="font-sans text-pergamino/85 text-base leading-relaxed">{fase.body}</p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.proceso-header',
    { y: 40, opacity: 0 },
    { scrollTrigger: { trigger: '.proceso-header', start: 'top 90%' }, y: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );

  document.querySelectorAll('.fase-row').forEach((el) => {
    gsap.fromTo(el,
      { y: 60, opacity: 0 },
      { scrollTrigger: { trigger: el, start: 'top 90%' }, y: 0, opacity: 1, duration: 1, ease: 'power3.out' }
    );
  });
</script>

<style>
  .bg-hueso       { background-color: var(--color-hueso); }
  .bg-noche       { background-color: var(--color-noche); }
  .text-noche     { color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .bg-oro         { background-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
