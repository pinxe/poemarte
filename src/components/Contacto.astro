---
interface Props {
  eyebrow: string;
  title: string;
  tagline: string;
  email: string;
  orLabel: string;
  formspreeId: string;
  nameLabel: string;
  emailLabel: string;
  messageLabel: string;
  sendLabel: string;
}

const { eyebrow, title, tagline, email, orLabel, formspreeId, nameLabel, emailLabel, messageLabel, sendLabel } = Astro.props;
---

<section class="min-h-[100svh] flex items-center py-section px-6 md:px-16 bg-noche relative overflow-hidden">

  <span class="absolute right-0 bottom-0 font-serif text-[20rem] md:text-[40rem] leading-none text-pergamino/[0.02] select-none pointer-events-none">.</span>

  <div class="max-w-7xl mx-auto w-full grid md:grid-cols-2 gap-14 md:gap-32 items-start md:items-center relative z-10">

    <div class="contact-text flex flex-col gap-8 opacity-0">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro">{eyebrow}</p>
      <h1 class="font-serif text-[clamp(2rem,8vw,5rem)] leading-tight text-pergamino">{title}</h1>
      <p class="font-serif italic text-pergamino/90 text-lg md:text-xl leading-relaxed max-w-md">{tagline}</p>

      <div class="border-t border-pergamino/15 pt-8 mt-4">
        <p class="font-sans text-sm text-pergamino/85 mb-3">{orLabel}</p>
        <a href={`mailto:${email}`} class="font-serif italic text-oro text-xl md:text-2xl break-words hover:text-pergamino transition-colors duration-300">
          {email}
        </a>
      </div>
    </div>

    <form
      class="contact-form flex flex-col gap-6 opacity-0"
      action={`https://formspree.io/f/${formspreeId}`}
      method="POST"
    >

      <div class="flex flex-col gap-3">
        <label for="name" class="font-sans text-sm tracking-[0.3em] uppercase text-pergamino font-medium">{nameLabel}</label>
        <input id="name" name="name" type="text" required
          class="bg-transparent border-b border-pergamino/30 py-4 text-pergamino focus:border-oro outline-none transition-colors duration-300 font-sans text-lg md:text-xl" />
      </div>

      <div class="flex flex-col gap-3">
        <label for="email" class="font-sans text-sm tracking-[0.3em] uppercase text-pergamino font-medium">{emailLabel}</label>
        <input id="email" name="email" type="email" required
          class="bg-transparent border-b border-pergamino/30 py-4 text-pergamino focus:border-oro outline-none transition-colors duration-300 font-sans text-lg md:text-xl" />
      </div>

      <div class="flex flex-col gap-3">
        <label for="message" class="font-sans text-sm tracking-[0.3em] uppercase text-pergamino font-medium">{messageLabel}</label>
        <textarea id="message" name="message" rows="5" required
          class="bg-transparent border-b border-pergamino/30 py-4 text-pergamino focus:border-oro outline-none transition-colors duration-300 font-sans text-lg md:text-xl resize-none leading-relaxed"></textarea>
      </div>

      <button type="submit"
        class="self-start mt-6 flex items-center gap-4 font-sans text-sm tracking-[0.3em] uppercase text-pergamino hover:text-oro transition-colors duration-300 group font-medium">
        <span>{sendLabel}</span>
        <span class="block w-8 h-px bg-pergamino group-hover:bg-oro group-hover:w-12 transition-all duration-300"></span>
      </button>

    </form>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.contact-text',
    { y: 30, opacity: 0 },
    { scrollTrigger: { trigger: '.contact-text', start: 'top 90%' }, y: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
  gsap.fromTo('.contact-form',
    { y: 30, opacity: 0 },
    { scrollTrigger: { trigger: '.contact-form', start: 'top 90%' }, y: 0, opacity: 1, duration: 1, delay: 0.2, ease: 'power3.out' }
  );
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .bg-oro         { background-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
