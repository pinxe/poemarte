---
interface Props {
  eyebrow: string;
  title: string;
  tagline: string;
  email: string;
  orLabel: string;
}

const { eyebrow, title, tagline, email, orLabel } = Astro.props;
---

<section class="min-h-[100svh] flex items-center py-section px-6 md:px-16 bg-noche relative overflow-hidden">

  <span class="absolute right-0 bottom-0 font-serif text-[20rem] md:text-[40rem] leading-none text-pergamino/[0.02] select-none pointer-events-none">.</span>

  <div class="max-w-3xl mx-auto w-full text-center relative z-10">

    <div class="contact-text flex flex-col gap-8 items-center opacity-0">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro">{eyebrow}</p>
      <h1 class="font-serif text-[clamp(2rem,8vw,5rem)] leading-tight text-pergamino">{title}</h1>
      <p class="font-serif italic text-pergamino/90 text-lg md:text-xl leading-relaxed max-w-md">{tagline}</p>

      <div class="border-t border-pergamino/15 pt-8 mt-4 w-full max-w-md">
        <p class="font-sans text-sm text-pergamino/85 mb-3">{orLabel}</p>
        <a href={`mailto:${email}`} class="font-serif italic text-oro text-xl md:text-2xl break-words hover:text-pergamino transition-colors duration-300">
          {email}
        </a>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.contact-text',
    { y: 30, opacity: 0 },
    { scrollTrigger: { trigger: '.contact-text', start: 'top 90%' }, y: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .bg-oro         { background-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
