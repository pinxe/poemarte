---
import { useTranslations } from '../i18n';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="presentacion" class="relative py-section px-8 md:px-16 bg-hueso overflow-hidden">

  <!-- Número decorativo de fondo -->
  <span class="absolute right-8 top-8 font-serif text-[20rem] leading-none text-noche/5 select-none pointer-events-none">
    01
  </span>

  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 md:gap-32 items-center">

    <!-- Columna izquierda: imagen -->
    <div class="reveal-left relative">
      <div class="aspect-[3/4] overflow-hidden">
        <img
          src="/images/presentacion.jpg"
          alt="Poemarte"
          class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-700"
        />
      </div>
      <!-- Marco decorativo desplazado -->
      <div class="absolute -bottom-6 -right-6 w-full h-full border border-oro/20 z-[-1]"></div>
    </div>

    <!-- Columna derecha: texto -->
    <div class="reveal-right flex flex-col gap-8">

      <!-- Etiqueta -->
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro">
        Poemarte
      </p>

      <!-- Título concepto -->
      <h2 class="font-serif text-[clamp(2rem,5vw,3.5rem)] leading-tight text-noche">
        {t('presentation.concept')}
      </h2>

      <!-- Cita destacada -->
      <blockquote class="border-l-2 border-oro pl-6">
        <p class="font-serif italic text-noche/75 text-lg leading-relaxed">
          {t('presentation.tagline')}
        </p>
      </blockquote>

      <!-- Cuerpo de texto -->
      <div class="flex flex-col gap-5">
        <p class="font-sans text-base text-noche/85 leading-relaxed">
          {t('presentation.body1')}
        </p>
        <p class="font-sans text-base text-noche/85 leading-relaxed">
          {t('presentation.body2')}
        </p>
      </div>

      <!-- Cierre poético -->
      <p class="font-serif italic text-noche text-base mt-4">
        {t('presentation.body3')}
      </p>

    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.reveal-left', {
    scrollTrigger: { trigger: '.reveal-left', start: 'top 80%' },
    x: -60,
    opacity: 0,
    duration: 1,
    ease: 'power3.out',
  });

  gsap.from('.reveal-right', {
    scrollTrigger: { trigger: '.reveal-right', start: 'top 80%' },
    x: 60,
    opacity: 0,
    duration: 1,
    ease: 'power3.out',
  });
</script>

<style>
  .bg-hueso    { background-color: var(--color-hueso); }
  .text-noche  { color: var(--color-noche); }
  .text-oro    { color: var(--color-oro); }
  .border-oro  { border-color: var(--color-oro); }
  .font-serif  { font-family: var(--font-serif); }
  .font-sans   { font-family: var(--font-sans); }
  .py-section  { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
