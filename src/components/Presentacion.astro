---
interface Props {
  eyebrow: string;
  concept: string;
  quote: string;
  body1: string;
  body2: string;
  body3: string;
  image: string;
}

const { eyebrow, concept, quote, body1, body2, body3, image } = Astro.props;
---

<section id="presentacion" class="relative py-section px-6 md:px-16 bg-hueso overflow-hidden">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 md:gap-32 items-center">

    <div class="reveal-left relative">
      <div class="aspect-[3/4] overflow-hidden">
        <img src={image} alt="Poemarte" loading="lazy" decoding="async" class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-700" />
      </div>
      <div class="absolute -bottom-6 -right-6 w-full h-full border border-oro/20 z-[-1]"></div>
    </div>

    <div class="reveal-right flex flex-col gap-8">
      <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro">{eyebrow}</p>
      <h2 class="font-serif text-[clamp(2rem,5vw,3.5rem)] leading-tight text-noche">{concept}</h2>
      <blockquote class="border-l-2 border-oro pl-6">
        <p class="font-serif italic text-noche/90 text-xl md:text-2xl leading-relaxed">{quote}</p>
      </blockquote>
      <div class="flex flex-col gap-5">
        <p class="font-sans text-base md:text-lg text-noche leading-relaxed">{body1}</p>
        <p class="font-sans text-base md:text-lg text-noche leading-relaxed">{body2}</p>
      </div>
      <p class="font-serif italic text-noche text-lg md:text-xl mt-4">{body3}</p>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('.reveal-left',
    { x: -60, opacity: 0 },
    { scrollTrigger: { trigger: '.reveal-left', start: 'top 90%' }, x: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
  gsap.fromTo('.reveal-right',
    { x: 60, opacity: 0 },
    { scrollTrigger: { trigger: '.reveal-right', start: 'top 90%' }, x: 0, opacity: 1, duration: 1, ease: 'power3.out' }
  );
</script>

<style>
  .bg-hueso   { background-color: var(--color-hueso); }
  .text-noche { color: var(--color-noche); }
  .text-oro   { color: var(--color-oro); }
  .border-oro { border-color: var(--color-oro); }
  .font-serif { font-family: var(--font-serif); }
  .font-sans  { font-family: var(--font-sans); }
  .py-section { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
