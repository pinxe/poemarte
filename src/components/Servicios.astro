---
import { getLocalePath } from '../i18n';
import type { Locale } from '../i18n';

interface ServiceItem {
  title: string;
  subtitle: string;
  imageList: string;
}

interface Props {
  locale: Locale;
  eyebrow: string;
  heading: string;
  seeAllLabel: string;
  items: ServiceItem[];
}

const { locale, eyebrow, heading, seeAllLabel, items } = Astro.props;
---

<section id="servicios" class="py-section px-8 md:px-16 bg-noche">
  <div class="max-w-7xl mx-auto">

    <div class="reveal-up flex items-end justify-between mb-16">
      <div>
        <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-4">{eyebrow}</p>
        <h2 class="font-serif text-[clamp(2rem,5vw,3.5rem)] text-pergamino leading-tight">{heading}</h2>
      </div>
      <a
        href={getLocalePath(locale, 'servicios')}
        class="hidden md:flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase text-ceniza hover:text-oro transition-colors duration-300 group"
      >
        <span>{seeAllLabel}</span>
        <span class="block w-8 h-px bg-ceniza group-hover:bg-oro group-hover:w-12 transition-all duration-300"></span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-pergamino/10">
      {items.map((item, i) => (
        <article class="service-card relative overflow-hidden bg-noche group aspect-[4/3]">
          <img
            src={item.imageList}
            alt={item.title}
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700"
          />
          <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-10">
            <span class="font-serif text-6xl text-pergamino/10 leading-none">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="font-serif text-2xl md:text-3xl text-pergamino mb-2 leading-tight">{item.title}</h3>
              <p class="font-serif italic text-ceniza text-sm">{item.subtitle}</p>
              <div class="mt-6 w-0 h-px bg-oro group-hover:w-12 transition-all duration-500"></div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo('#servicios .reveal-up',
    { y: 40, opacity: 0 },
    { scrollTrigger: { trigger: '#servicios .reveal-up', start: 'top 90%' }, y: 0, opacity: 1, duration: 0.9, ease: 'power3.out' }
  );

  gsap.fromTo('.service-card',
    { y: 50, opacity: 0 },
    { scrollTrigger: { trigger: '.service-card', start: 'top 90%' }, y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: 'power3.out' }
  );
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .bg-oro         { background-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
