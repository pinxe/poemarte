---
import { useTranslations, getLocalePath } from '../i18n';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const items = [
  {
    key:   'exposiciones',
    image: '/images/servicio-exposiciones.jpg',
    num:   '01',
  },
  {
    key:   'artesanales',
    image: '/images/servicio-artesanales.jpg',
    num:   '02',
  },
  {
    key:   'colaboraciones',
    image: '/images/servicio-colaboraciones.jpg',
    num:   '03',
  },
  {
    key:   'merchandising',
    image: '/images/servicio-merchandising.jpg',
    num:   '04',
  },
];
---

<section id="servicios" class="py-section px-8 md:px-16 bg-noche">
  <div class="max-w-7xl mx-auto">

    <!-- Cabecera de sección -->
    <div class="flex items-end justify-between mb-16 reveal-up">
      <div>
        <p class="font-sans text-[10px] tracking-[0.5em] uppercase text-oro mb-4">
          {t('services.title')}
        </p>
        <h2 class="font-serif text-[clamp(2rem,5vw,3.5rem)] text-pergamino leading-tight">
          Lo que hacemos
        </h2>
      </div>
      <a
        href={getLocalePath(locale, 'servicios')}
        class="hidden md:flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase text-ceniza hover:text-oro transition-colors duration-300 group"
      >
        <span>Ver todos</span>
        <span class="block w-8 h-px bg-ceniza group-hover:bg-oro group-hover:w-12 transition-all duration-300"></span>
      </a>
    </div>

    <!-- Grid 2x2 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-pergamino/10">
      {items.map((item, i) => (
        <article class="service-card relative overflow-hidden bg-noche group aspect-[4/3]">

          <!-- Imagen de fondo -->
          <img
            src={item.image}
            alt={t(`services.${item.key}`)}
            class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700"
          />

          <!-- Contenido -->
          <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-10">
            <span class="font-serif text-6xl text-pergamino/10 leading-none">{item.num}</span>
            <div>
              <h3 class="font-serif text-2xl md:text-3xl text-pergamino mb-2 leading-tight">
                {t(`services.${item.key}`)}
              </h3>
              <p class="font-serif italic text-ceniza text-sm">
                {t(`services.${item.key}_sub`)}
              </p>
              <!-- Línea animada en hover -->
              <div class="mt-6 w-0 h-px bg-oro group-hover:w-12 transition-all duration-500"></div>
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.reveal-up', {
    scrollTrigger: { trigger: '.reveal-up', start: 'top 85%' },
    y: 40,
    opacity: 0,
    duration: 0.9,
    ease: 'power3.out',
  });

  gsap.from('.service-card', {
    scrollTrigger: { trigger: '.service-card', start: 'top 85%' },
    y: 50,
    opacity: 0,
    duration: 0.8,
    stagger: 0.15,
    ease: 'power3.out',
  });
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-ceniza    { color: var(--color-ceniza); }
  .text-oro       { color: var(--color-oro); }
  .bg-oro         { background-color: var(--color-oro); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }
  .py-section     { padding-top: var(--spacing-section); padding-bottom: var(--spacing-section); }
</style>
