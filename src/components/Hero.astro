---
interface Props {
  title: string;
  subtitle: string;
  tagline: string;
  image: string;
}

const { title, subtitle, tagline, image } = Astro.props;
---

<section id="hero" class="relative min-h-[100svh] flex flex-col items-center justify-center overflow-hidden">

  <div id="hero-bg" class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-noche/75 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-noche/40 via-transparent to-noche/70 z-10"></div>
    <img
      id="hero-img"
      src={image}
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-full h-full object-cover scale-110"
    />
  </div>

  <div id="hero-line-left" class="hidden md:flex absolute left-8 md:left-16 top-1/2 -translate-y-1/2 flex-col items-center gap-4 z-20 opacity-0">
    <div class="w-px h-24 bg-oro/40"></div>
    <p class="font-sans text-[10px] tracking-[0.4em] uppercase text-ceniza writing-vertical">
      {subtitle}
    </p>
  </div>

  <div class="relative z-20 text-center px-6 md:px-8 flex flex-col items-center">

    <p id="hero-eyebrow" class="font-sans text-sm tracking-[0.5em] uppercase text-oro mb-10 opacity-0 hero-shadow font-medium">
      {subtitle}
    </p>

    <h1 id="hero-title" class="hero-title font-serif text-pergamino uppercase leading-none whitespace-nowrap hero-shadow">
      {title.split('').map((char: string) => (
        <span class="hero-char inline-block opacity-0">{char === ' ' ? ' ' : char}</span>
      ))}
    </h1>

    <div id="hero-divider" class="w-0 h-px bg-oro/70 my-10 opacity-0"></div>

    <p id="hero-tagline" class="font-serif italic text-pergamino text-xl md:text-2xl max-w-xl leading-relaxed opacity-0 hero-shadow">
      {tagline}
    </p>

    <a
      id="hero-cta"
      href="#presentacion"
      class="mt-16 opacity-0 flex flex-col items-center gap-3 group"
      aria-label="Bajar"
    >
      <div class="w-px h-16 bg-gradient-to-b from-pergamino to-transparent group-hover:from-oro transition-colors duration-300"></div>
    </a>

  </div>

</section>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.4 });

  tl.to('.hero-char', { opacity: 1, duration: 0.9, stagger: 0.06, ease: 'power1.inOut' })
    .to('#hero-eyebrow', { opacity: 1, duration: 0.8, ease: 'power2.out' }, '-=0.6')
    .to('#hero-divider', { opacity: 1, width: '4rem', duration: 0.8, ease: 'power2.out' }, '-=0.3')
    .to('#hero-tagline', { opacity: 1, duration: 1, ease: 'power2.out' }, '-=0.5')
    .to('#hero-line-left', { opacity: 1, duration: 1, ease: 'power2.out' }, '-=0.5')
    .to('#hero-cta', { opacity: 1, duration: 0.8, ease: 'power2.out' }, '-=0.3');

  const heroImg = document.getElementById('hero-img');
  window.addEventListener('scroll', () => {
    if (heroImg) heroImg.style.transform = `scale(1.1) translateY(${window.scrollY * 0.3}px)`;
  }, { passive: true });
</script>

<style>
  .bg-noche       { background-color: var(--color-noche); }
  .text-pergamino { color: var(--color-pergamino); }
  .text-oro       { color: var(--color-oro); }
  .text-ceniza    { color: var(--color-ceniza); }
  .font-serif     { font-family: var(--font-serif); }
  .font-sans      { font-family: var(--font-sans); }

  .writing-vertical {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .hero-shadow {
    text-shadow: 0 2px 18px rgba(0,0,0,0.65), 0 1px 3px rgba(0,0,0,0.5);
  }

  /* Hero title: escala desde el ancho del viewport y reduce tracking en móvil
     para evitar que "POEMARTE" rompa en dos líneas en pantallas estrechas */
  .hero-title {
    font-size: clamp(2.75rem, 13vw, 14rem);
    letter-spacing: 0.02em;
  }
  @media (min-width: 768px) {
    .hero-title { letter-spacing: 0.15em; }
  }
</style>
