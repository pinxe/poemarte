---
import Layout from '../layouts/Layout.astro';
import LegalPage from '../components/LegalPage.astro';
import { getAvisoLegal } from '../lib/content';
import { renderMarkdoc } from '../lib/markdoc';

const data = await getAvisoLegal();
if (!data) throw new Error('Falta contenido: Aviso Legal');

const bodyAny: any = data.body;
const node = typeof bodyAny === 'function' ? (await bodyAny()).node : (bodyAny?.node ?? bodyAny);
const html = await renderMarkdoc(node);
---

<Layout locale="es" title={data.title} currentPath="aviso-legal">
  <LegalPage title={data.title} updated={data.updated} bodyHtml={html} />
</Layout>
