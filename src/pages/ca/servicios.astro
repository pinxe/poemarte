---
import Layout from '../../layouts/Layout.astro';
import ServiciosHero from '../../components/servicios/ServiciosHero.astro';
import ServicioDetalle from '../../components/servicios/ServicioDetalle.astro';
import { useTranslations } from '../../i18n';

const locale = 'ca';
const t = useTranslations(locale);

const servicios = [
  {
    num:      '01',
    title:    t('services.exposiciones'),
    subtitle: t('services.exposiciones_sub'),
    body:     'Poemes creats des de l\'escolta de cada obra per acompanyar exposicions individuals o col·lectives. Els textos poden integrar-se com a cartel·les, textos de sala, catàlegs o experiències immersives.',
    image:    '/images/servicio-exposiciones-detalle.jpg',
  },
  {
    num:      '02',
    title:    t('services.artesanales'),
    subtitle: t('services.artesanales_sub'),
    body:     'Per a artesans i creadors de peces úniques: un poema que acompanya l\'obra i la converteix en quelcom més que un objecte. Una història, una emoció, un segell poètic.',
    image:    '/images/servicio-artesanales-detalle.jpg',
  },
  {
    num:      '03',
    title:    t('services.colaboraciones'),
    subtitle: t('services.colaboraciones_sub'),
    body:     'Col·laboracions a mida amb artistes, galeries i projectes culturals. Cada paraula neix del diàleg amb l\'obra i respecta la identitat de qui la crea.',
    image:    '/images/servicio-colaboraciones-detalle.jpg',
  },
  {
    num:      '04',
    title:    t('services.merchandising'),
    subtitle: t('services.merchandising_sub'),
    body:     'Objectes on la poesia es torna tangible: targetes, edicions limitades, peces editorials. El poema surt del marc per acompanyar el públic.',
    image:    '/images/servicio-merchandising-detalle.jpg',
  },
];
---

<Layout locale={locale} title={t('services.title')} currentPath="servicios">
  <ServiciosHero locale={locale} />
  {servicios.map((s, i) => (
    <ServicioDetalle num={s.num} title={s.title} subtitle={s.subtitle} body={s.body} image={s.image} reverse={i % 2 === 1} />
  ))}
</Layout>
