---
import Layout from '../layouts/Layout.astro';
import ServiciosHero from '../components/servicios/ServiciosHero.astro';
import ServicioDetalle from '../components/servicios/ServicioDetalle.astro';
import { useTranslations } from '../i18n';
import { getServicios } from '../lib/content';

const locale = 'es';
const t = useTranslations(locale);
const serv = await getServicios();
---

<Layout locale={locale} title={serv.heroTitle} currentPath="servicios">
  <ServiciosHero
    eyebrow={t('nav.services')}
    title={serv.heroTitle}
    tagline={serv.heroTagline}
    image={serv.heroImage ?? '/images/cms/servicios-hero.jpg'}
  />
  {serv.items.map((s, i) => (
    <ServicioDetalle
      num={String(i + 1).padStart(2, '0')}
      title={s.title}
      subtitle={s.subtitle}
      body={s.body}
      image={s.image ?? ''}
      reverse={i % 2 === 1}
    />
  ))}
</Layout>
