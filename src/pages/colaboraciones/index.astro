---
import Layout from '../../layouts/Layout.astro';
import Colaboraciones from '../../components/Colaboraciones.astro';
import SobreHero from '../../components/sobre/SobreHero.astro';
import { useTranslations } from '../../i18n';
import { getHome, getColaboraciones } from '../../lib/content';

const locale = 'es';
const t = useTranslations(locale);

const home = await getHome();
const colabs = await getColaboraciones();
---

<Layout locale={locale} title={home.collabsTitle} currentPath="colaboraciones">
  <SobreHero
    eyebrow={home.collabsTitle}
    title={home.collabsTagline}
    image={'/images/cms/heroImage.jpg'}
  />
  <Colaboraciones
    locale={locale}
    eyebrow={home.collabsTitle}
    tagline={home.collabsTagline}
    viewLabel={t('ui.view_collab')}
    items={colabs.map(c => ({
      slug: c.slug,
      titulo: c.titulo,
      imagenPrincipal: c.imagenPrincipal ?? '',
    }))}
  />
</Layout>
