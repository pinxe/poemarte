---
import Layout from '../../layouts/Layout.astro';
import Colaboraciones from '../../components/Colaboraciones.astro';
import SobreHero from '../../components/sobre/SobreHero.astro';
import { useTranslations } from '../../i18n';
import { getColaboracionesPage, getColaboraciones } from '../../lib/content';

const locale = 'es';
const t = useTranslations(locale);

const page = await getColaboracionesPage();
const colabs = await getColaboraciones();
---

<Layout locale={locale} title={page.heroTitle} currentPath="colaboraciones">
  <SobreHero
    eyebrow={page.heroTitle}
    title={page.heroTagline}
    image={page.heroImage ?? '/images/cms/heroImage.jpg'}
  />
  <Colaboraciones
    locale={locale}
    eyebrow={page.heroTitle}
    tagline={page.heroTagline}
    viewLabel={t('ui.view_collab')}
    items={colabs.map(c => ({
      slug: c.slug,
      titulo: c.titulo,
      imagenPrincipal: c.imagenPrincipal ?? '',
    }))}
  />
</Layout>
