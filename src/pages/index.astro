---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Presentacion from '../components/Presentacion.astro';
import Servicios from '../components/Servicios.astro';
import Colaboraciones from '../components/Colaboraciones.astro';
import { useTranslations } from '../i18n';
import { getHome, getServiciosItems, getColaboraciones } from '../lib/content';

const locale = 'es';
const t = useTranslations(locale);

const home = await getHome();
const servItems = await getServiciosItems();
const colabs = (await getColaboraciones()).filter(c => c.destacada).slice(0, 3);
---

<Layout locale={locale}>
  <Hero
    title={home.heroTitle}
    subtitle={home.heroSubtitle}
    tagline={home.heroTagline}
    image={home.heroImage ?? '/images/cms/home-hero.jpg'}
  />
  <Presentacion
    eyebrow={home.presentationEyebrow}
    concept={home.presentationConcept}
    quote={home.presentationQuote}
    body1={home.presentationBody1}
    body2={home.presentationBody2}
    body3={home.presentationBody3}
    image={home.presentationImage ?? '/images/cms/home-presentacion.jpg'}
  />
  <Servicios
    locale={locale}
    eyebrow={t('nav.services')}
    heading={home.servicesHeading}
    seeAllLabel={t('ui.see_all')}
    items={servItems.map(it => ({
      slug: it.slug,
      title: it.title,
      subtitle: it.subtitle,
      imageList: it.imageList ?? it.image ?? '',
    }))}
  />
  <Colaboraciones
    locale={locale}
    eyebrow={home.collabsTitle}
    tagline={home.collabsTagline}
    viewLabel={t('ui.view_collab')}
    items={colabs.map(c => ({
      slug: c.slug,
      titulo: c.titulo,
      imagenPrincipal: c.imagenPrincipal ?? '',
    }))}
  />
</Layout>
