---
import Layout from '../../layouts/Layout.astro';
import ServiciosHero from '../../components/servicios/ServiciosHero.astro';
import ServicioDetalle from '../../components/servicios/ServicioDetalle.astro';
import { useTranslations } from '../../i18n';

const locale = 'en';
const t = useTranslations(locale);

const servicios = [
  {
    num:      '01',
    title:    t('services.exposiciones'),
    subtitle: t('services.exposiciones_sub'),
    body:     'Poems born from listening to each work, designed to accompany individual or collective exhibitions. Texts can be integrated as labels, room texts, catalogues or immersive experiences.',
    image:    '/images/servicio-exposiciones-detalle.jpg',
  },
  {
    num:      '02',
    title:    t('services.artesanales'),
    subtitle: t('services.artesanales_sub'),
    body:     'For craftspeople and creators of unique pieces: a poem that accompanies the work and turns it into something more than an object. A story, an emotion, a poetic seal.',
    image:    '/images/servicio-artesanales-detalle.jpg',
  },
  {
    num:      '03',
    title:    t('services.colaboraciones'),
    subtitle: t('services.colaboraciones_sub'),
    body:     'Bespoke collaborations with artists, galleries and cultural projects. Each word is born from dialogue with the work and respects the identity of its creator.',
    image:    '/images/servicio-colaboraciones-detalle.jpg',
  },
  {
    num:      '04',
    title:    t('services.merchandising'),
    subtitle: t('services.merchandising_sub'),
    body:     'Objects where poetry becomes tangible: cards, limited editions, editorial pieces. The poem leaves the frame to accompany the public in their everyday life.',
    image:    '/images/servicio-merchandising-detalle.jpg',
  },
];
---

<Layout locale={locale} title={t('services.title')} currentPath="servicios">
  <ServiciosHero locale={locale} />
  {servicios.map((s, i) => (
    <ServicioDetalle num={s.num} title={s.title} subtitle={s.subtitle} body={s.body} image={s.image} reverse={i % 2 === 1} />
  ))}
</Layout>
