# Keystatic CMS — credenciales de la GitHub App.
# Solo se necesitan en producción (Vercel). En local funciona con storage
# de tipo "local" sin estas variables.
#
# Cómo obtenerlas:
#   1. Arranca el sitio en local: npm run dev
#   2. Ve a http://localhost:4321/keystatic/setup
#   3. Sigue el wizard: crea una GitHub App apuntando al repo pinxe/poemarte
#   4. Al terminar, Keystatic te enseña los valores. Pégalos aquí y en Vercel.

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
